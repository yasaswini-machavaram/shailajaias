{
  "name": "shailaja-ias",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:all": "turbo run dev --filter=api --filter=client --no-daemon",
    "build:all": "turbo run build",
    "lint:all": "turbo run lint",
    "check-types:all": "turbo run check-types",
    "preinstall": "npx only-allow pnpm",
    "nuke": "kill -9 $(lsof -t -i:3000 -i:3001 -i:4000) || true && pnpm run dev:all"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.7.4"
  }
}